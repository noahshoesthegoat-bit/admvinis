local function rebuildTickers()
    local appGui = PlayerGui:FindFirstChild("AdminChatApp")
    if not appGui then
        appGui = Instance.new("ScreenGui")
        appGui.Name = "AdminChatApp"
        appGui.ResetOnSpawn = false
        appGui.DisplayOrder = 10
        appGui.Parent = PlayerGui
    end
    appGui.Enabled = true
    for _,v in ipairs(appGui:GetChildren()) do
        if v.Name == "_FakeTicker" then v:Destroy() end
    end
    for _,c in ipairs(tickerConnections) do c:Disconnect() end
    tickerConnections = {}
    tickerContainers = {}
    if #currentEntries == 0 then return end
    local PADDING = 20
    local cycleWidth = 0
    for _,e in ipairs(currentEntries) do
        e.width = TextService:GetTextSize(e.text, 24, Enum.Font.FredokaOne, Vector2.new(math.huge,math.huge)).X
        cycleWidth = cycleWidth + e.width + PADDING
    end
    local function makeTicker(isBottom)
        local aY = isBottom and 1 or 0
        local fr = Instance.new("Frame")
        fr.Name = "_FakeTicker"
        fr.Size = UDim2.new(1,0,0,40)
        fr.AnchorPoint = Vector2.new(0.5,aY)
        fr.Position = UDim2.fromScale(0.5,aY)
        fr.BackgroundColor3 = Color3.new(0,0,0)
        fr.BackgroundTransparency = 0.75
        fr.BorderSizePixel = 0
        fr.ClipsDescendants = true
        fr.ZIndex = 9
        fr.Parent = appGui
        local ct = Instance.new("Frame")
        ct.BackgroundTransparency = 1
        ct.Size = UDim2.new(0,cycleWidth*2,1,0)
        ct.ZIndex = 10
        ct.Parent = fr
        table.insert(tickerContainers, ct)
        local ll = Instance.new("UIListLayout")
        ll.FillDirection = Enum.FillDirection.Horizontal
        ll.Padding = UDim.new(0,PADDING)
        ll.SortOrder = Enum.SortOrder.LayoutOrder
        ll.Parent = ct
        for _=1,2 do
            for _,e in ipairs(currentEntries) do mkLbl(e,e.width,ct) end
        end
        ct.Position = UDim2.fromOffset(isBottom and -(cycleWidth/2) or 0, 0)
        local conn = RunService.Heartbeat:Connect(function(dt)
            if not ct.Parent then return end
            local x = ct.Position.X.Offset - 80*dt
            if x <= -cycleWidth then x = x + cycleWidth end
            ct.Position = UDim2.fromOffset(x, 0)
        end)
        table.insert(tickerConnections, conn)
    end
    makeTicker(false)
    makeTicker(true)
end

local function spawnTickers(entries)
    currentEntries = entries
    rebuildTickers()
end

local function addToTickers(entry)
    table.insert(currentEntries, entry)
    rebuildTickers()
end

