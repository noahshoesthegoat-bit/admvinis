local function h2c(h)
    h = h:gsub("#","")
    return Color3.new(tonumber(h:sub(1,2),16)/255, tonumber(h:sub(3,4),16)/255, tonumber(h:sub(5,6),16)/255)
end

local function mkg(c)
    if #c == 1 then local x = h2c(c[1]) return ColorSequence.new(x,x) end
    local k = {}
    for i,v in ipairs(c) do k[i] = ColorSequenceKeypoint.new((i-1)/(#c-1), h2c(v)) end
    return ColorSequence.new(k)
end

