local function GetPropertyGroup(p)
    local M,N,F,R = p.mega_neon or false, p.neon or false, p.flyable or false, p.rideable or false
    if M then
        if F and R then return "mega_neon_flyable_rideable" elseif F then return "mega_neon_flyable" elseif R then return "mega_neon_rideable" else return "mega_neon" end
    elseif N then
        if F and R then return "neon_flyable_rideable" elseif F then return "neon_flyable" elseif R then return "neon_rideable" else return "neon" end
    else
        if F and R then return "flyable_rideable" elseif F then return "flyable" elseif R then return "rideable" else return "regular" end
    end
end

local function UpdateClientData(key, fn)
    local id = getIdentity()
    setIdentity(2)
    local data = ClientData.get(key)
    local result = fn(table.clone(data))
    ClientData.predict(key, result)
    setIdentity(id)
    return result
end

local function GenUID() return HttpService:GenerateGUID(false) end

local function FindIn(arr, fn)
    for i,v in pairs(arr) do if fn(v,i) then return i end end
end

local function FetchPetModel(kind)
    if PetModelCache[kind] then return PetModelCache[kind] end
    local m = DownloadClient.promise_download_copy("Pets", kind):expect()
    PetModelCache[kind] = m
    return m
end

local function StopMegaNeon(uid)
    local c = MegaNeonConnections[uid]
    if c then pcall(function() c:Disconnect() end) MegaNeonConnections[uid] = nil end
end

local function ApplyNeon(model, petData)
    local mi = model:FindFirstChild("PetModel")
    if not mi or not KindDB then return end
    local kd = KindDB[petData.id]
    if not kd then return end
    if petData.properties.mega_neon then
        local parts = kd.mega_neon_parts or kd.neon_parts
        if parts then pcall(PetNeonHelper.apply_neon, mi, parts) end
        StopMegaNeon(petData.unique)
        local state = {}
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if mi and mi.Parent and mi:IsDescendantOf(workspace) then
                pcall(PetNeonHelper.step_mega_neon, state, mi, kd)
            else
                if conn then conn:Disconnect() end
                MegaNeonConnections[petData.unique] = nil
            end
        end)
        MegaNeonConnections[petData.unique] = conn
    elseif petData.properties.neon then
        if kd.neon_parts then pcall(PetNeonHelper.apply_neon, mi, kd.neon_parts) end
    end
end

local function RegWrapper(data)
    UpdateClientData("pet_char_wrappers", function(w)
        data.unique = #w+1
        data.index = #w+1
        w[#w+1] = data
        return w
    end)
end

local function RegState(data)
    UpdateClientData("pet_state_managers", function(m)
        m[#m+1] = data
        return m
    end)
end

local function RemWrapper(uid)
    UpdateClientData("pet_char_wrappers", function(w)
        local i = FindIn(w, function(v) return v.pet_unique == uid end)
        if i then
            table.remove(w, i)
            for j = i, #w do w[j].unique = j w[j].index = j end
        end
        return w
    end)
end

local function RemState(uid)
    local pet = SpawnedPets[uid]
    if not pet or not pet.model then return end
    UpdateClientData("pet_state_managers", function(m)
        local i = FindIn(m, function(v) return v.char == pet.model end)
        if i then table.remove(m, i) end
        return m
    end)
end

local function ClearPetStates(uid)
    local pet = SpawnedPets[uid]
    if not pet or not pet.model then return end
    UpdateClientData("pet_state_managers", function(m)
        local i = FindIn(m, function(v) return v.char == pet.model end)
        if i then
            local u = table.clone(m)
            u[i] = table.clone(u[i])
            u[i].states = {}
            return u
        end
        return m
    end)
end

local function SetPetState(uid, sid)
    local pet = SpawnedPets[uid]
    if not pet or not pet.model then return end
    UpdateClientData("pet_state_managers", function(m)
        local i = FindIn(m, function(v) return v.char == pet.model end)
        if i then
            local u = table.clone(m)
            u[i] = table.clone(u[i])
            u[i].states = {{id=sid}}
            return u
        end
        return m
    end)
end

local function ClearPlayerStates()
    UpdateClientData("state_manager", function(s)
        local u = table.clone(s)
        u.states = {}
        u.is_sitting = false
        return u
    end)
end

local function SetPlayerState(sid)
    UpdateClientData("state_manager", function(s)
        local u = table.clone(s)
        u.states = {{id=sid}}
        u.is_sitting = true
        return u
    end)
end

local function AttachRide(model)
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return false end
    local rp = model:FindFirstChild("RidePosition", true)
    if not rp then return false end
    local a = Instance.new("Attachment")
    a.Parent = rp
    a.Position = Vector3.new(0, 1.237, 0)
    a.Name = "SourceAttachment"
    local rc = Instance.new("RigidConstraint")
    rc.Name = "StateConnection"
    rc.Attachment0 = a
    rc.Attachment1 = char.PrimaryPart.RootAttachment
    rc.Parent = char
    return true
end

local function Dismount()
    if not CurrentRideId then return end
    local pet = SpawnedPets[CurrentRideId]
    if pet and pet.model then
        if RideAnimationTrack then
            RideAnimationTrack:Stop()
            RideAnimationTrack:Destroy()
            RideAnimationTrack = nil
        end
        local sa = pet.model:FindFirstChild("SourceAttachment", true)
        if sa then sa:Destroy() end
        local char = LocalPlayer.Character
        if char then
            for _,p in pairs(char:GetDescendants()) do
                if p:IsA("BasePart") and p:GetAttribute("HaveMass") then
                    p.Massless = false
                end
            end
        end
        ClearPetStates(CurrentRideId)
        ClearPlayerStates()
        pet.model:ScaleTo(1)
    end
    CurrentRideId = nil
end

local function Mount(uid, pState, petState)
    local pet = SpawnedPets[uid]
    if not pet or not pet.model then return end
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart or not char:FindFirstChild("Humanoid") then return end
    Dismount()
    CurrentRideId = uid
    SetPetState(uid, petState)
    SetPlayerState(pState)
    pet.model:ScaleTo(2)
    AttachRide(pet.model)
    RideAnimationTrack = char.Humanoid.Animator:LoadAnimation(AnimationManager.get_track("PlayerRidingPet"))
    char.Humanoid.Sit = true
    for _,p in pairs(char:GetDescendants()) do
        if p:IsA("BasePart") and p.Massless == false then
            p.Massless = true
            p:SetAttribute("HaveMass", true)
        end
    end
    RideAnimationTrack:Play()
end

local function UnequipPet(petData)
    local pet = SpawnedPets[petData.unique]
    if not pet or not pet.model then return end
    if CurrentRideId == petData.unique then Dismount() end
    StopMegaNeon(petData.unique)
    RemWrapper(petData.unique)
    RemState(petData.unique)
    pet.model:Destroy()
    pet.model = nil
    if EquippedPet and EquippedPet.unique == petData.unique then EquippedPet = nil end
    PetAilmentsCache[petData.unique] = nil
    task.wait(0.15)
    if AilmentsClient then pcall(AilmentsClient.on_ailments_changed, LocalPlayer) end
end

local function EquipPet(petData, options)
    if petData.category ~= "pets" then return end
    if EquippedPet then UnequipPet(EquippedPet) end
    for _,w in pairs(ClientData.get("pet_char_wrappers")) do
        if w.controller == LocalPlayer then
            pcall(function() RouterClient.get("ToolAPI/Unequip"):InvokeServer(w.pet_unique) end)
        end
    end
    if not SpawnedPets[petData.unique] then
        SpawnedPets[petData.unique] = {data=petData, model=nil}
    else
        SpawnedPets[petData.unique].data = petData
    end
    local model = FetchPetModel(petData.kind):Clone()
    pcall(function() CharacterScale.scale_pet(model, 1) end)
    if options and options.spawn_cframe then
        pcall(function() model:PivotTo(options.spawn_cframe) end)
        model:SetAttribute("HasSpawnCFrame", true)
    end
    model.Parent = workspace
    SpawnedPets[petData.unique].model = model
    ApplyNeon(model, petData)
    EquippedPet = petData
    local loc = nil
    pcall(function() loc = InteriorsM and InteriorsM.get_current_location() end)
    local destId = (loc and loc.destination_id) or "housing"
    local fullDestId = (loc and loc.full_destination_id) or destId
    local subDestId = loc and loc.sub_destination_id
    task.defer(function()
        RegWrapper({
            char=model, mega_neon=petData.properties.mega_neon or false,
            neon=petData.properties.neon or false, player=LocalPlayer,
            entity_controller=LocalPlayer, controller=LocalPlayer,
            rp_name=petData.properties.rp_name or "",
            pet_trick_level=petData.properties.pet_trick_level or 0,
            pet_unique=petData.unique, pet_id=petData.id,
            location={full_destination_id=fullDestId, destination_id=destId, sub_destination_id=subDestId, house_owner=LocalPlayer},
            pet_progression={age=petData.properties.age or 1, xp=petData.properties.xp or 0, friendship_level=1, friendship_xp=0, percentage=math.random(0,99)/100},
            are_colors_sealed=false, is_pet=true,
        })
        RegState({char=model, player=LocalPlayer, store_key="pet_state_managers", is_sitting=false, chars_connected_to_me={}, states={}})
        task.wait(0.1)
        pcall(function()
            UpdateClientData("pet_char_wrappers", function(w)
                for _,v in pairs(w) do
                    if v.pet_unique == petData.unique then v.rp_name = petData.properties.rp_name or "" end
                end
                return w
            end)
        end)
        task.wait(0.15)
        if AilmentsClient then pcall(AilmentsClient.on_ailments_changed, LocalPlayer) end
    end)
end

-- Ailments override
if ClientData then
    local origGS = ClientData.get_server
    ClientData.get_server = function(player, key, ...)
        local data = origGS(player, key, ...)
        if key == "ailments_manager" and player == LocalPlayer then
            local ad = {}
            if data then for k,v in pairs(data) do ad[k] = type(v)=="table" and table.clone(v) or v end end
            ad.ailments = ad.ailments or {}
            for uid,petInfo in pairs(SpawnedPets) do
                if petInfo and petInfo.model then
                    if PetAilmentsCache[uid] then
                        ad.ailments[uid] = PetAilmentsCache[uid]
                    else
                        local types = {}
                        if AilmentsDB then
                            for k in pairs(AilmentsDB) do
                                if k ~= "at_work" and k ~= "mystery" and k ~= "walking" then
                                    table.insert(types, k)
                                end
                            end
                        end
                        local petAils = {}
                        local used = {}
                        for i = 1, math.min(3, #types) do
                            local ak
                            repeat ak = types[math.random(1, #types)] until not used[ak]
                            used[ak] = true
                            petAils[GenUID()] = {components={}, created_timestamp=os.time(), kind=ak, progress=0, rate=0, rate_timestamp=os.time(), sort_order=i*100}
                        end
                        PetAilmentsCache[uid] = petAils
                        ad.ailments[uid] = petAils
                    end
                end
            end
            return ad
        end
        return data
    end
end

