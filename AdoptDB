-- Command handler
local function handleCmd(msg)
    local t = msg:gsub("^%s+",""):gsub("%s+$","")
    local l = t:lower()

    if l == "teleport/gold/me" then
        task.spawn(function()
            pcall(function()
                local interiors = workspace:FindFirstChild("Interiors")
                if interiors then
                    for _,c in ipairs(interiors:GetChildren()) do
                        if c.Name == "MainMap!Default" or c.Name:lower():find("mainmap") then
                            c.Name = "AdminAbuseGold"
                            break
                        end
                    end
                end
            end)
            if MusicModule then
                pcall(function() MusicModule.play(99,{id="rbxassetid://80082589176421",volume=0.25,name="AdminAbuseMusic"}) end)
            end
            spawnTickers({AE.multiplier_3x, AE.xp_rain})
        end)
        return
    end

    -- adminabuseevent/item_rain/<kind>[/age_N][/neon][/mega][/fly][/ride][/temporary][/untradeable]
    local itemArgs = t:match("^[Aa][Dd][Mm][Ii][Nn][Aa][Bb][Uu][Ss][Ee][Ee][Vv][Ee][Nn][Tt]/item[^/]+/(.+)$")
    if itemArgs then
        local isRain = t:lower():find("/item_rain/") ~= nil
        task.spawn(function()
            local parts = {}
            for p in itemArgs:gmatch("[^/]+") do table.insert(parts, p) end
            local itemName = parts[1]:lower()
            local age = 6
            local neon, mega, fly, ride = false, false, true, true
            local temporary, untradeable = false, false
            local friendship = 1
            for i = 2, #parts do
                local p = parts[i]:lower()
                local ageNum = p:match("^age_(%d+)$")
                local friendNum = p:match("^friendship_(%d+)$")
                if ageNum then age = tonumber(ageNum) or 6
                elseif friendNum then friendship = tonumber(friendNum) or 1
                elseif p == "neon" then neon = true
                elseif p == "mega" or p == "mega_neon" then mega = true neon = false
                elseif p == "fly" or p == "flyable" then fly = true
                elseif p == "ride" or p == "rideable" then ride = true
                elseif p == "nofly" then fly = false
                elseif p == "noride" then ride = false
                elseif p == "temporary" then temporary = true
                elseif p == "untradeable" then untradeable = true
                end
            end
            local itemId, itemCat, itemEntry = findItem(itemName)
            local name = (itemEntry and itemEntry.name) or itemName
            local text = isRain and ("It's raining: "..name.."!") or ("You got a free "..name.."! Check your Backpack!")
            addToTickers({text=text, colors=RAINBOW})
            local props = {neon=neon,mega_neon=mega,flyable=fly,rideable=ride,age=age,pet_trick_level=5,trick_level=5,ailments_completed=0,rp_name="",xp=0,friendship_level=friendship,friendship_xp=0}
            if temporary then props.temporary = true end
            if untradeable then props.untradeable = true end
            local ok, err = pcall(function()
                local UIManager
                pcall(function() UIManager = Fsys("UIManager") end)
                local DialogApp = UIManager and UIManager.apps and UIManager.apps.DialogApp
                local kd = KindDB and KindDB[itemId]
                if not kd then return end
                local response = DialogApp:dialog({
                    dialog_type = "ItemPreviewDialog",
                    text = "An Adopt Me admin gave you: ",
                    item = {id=itemId, name=name, category=itemCat or "pets", kind=kd.kind, properties=props},
                    button = "Okay!",
                    yields = true,
                })
                if response == "Okay!" and itemId then
                    local newItem = CreateItem(itemId, itemCat or "pets", props)
                end
            end)
            if not ok then warn("[AAP] error:", err) end
        end)
        return
    end

    local kind = t:match("^[Aa][Dd][Mm][Ii][Nn][Aa][Bb][Uu][Ss][Ee][Ee][Vv][Ee][Nn][Tt]/(.+)$")
    if kind then
        kind = kind:lower()
        local entry = AE[kind]
        if activeEvents[kind] then return end
        activeEvents[kind] = true
        if kind == "super_speed" then
            task.spawn(function()
                local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                pcall(function() char:WaitForChild("Humanoid").WalkSpeed = 35 end)
            end)
        elseif kind == "low_gravity" then
            pcall(function() workspace.Gravity = 50 end)
        end
        addToTickers(entry)
        return
    end

    if l == "teleport/housing/me" then
        if InteriorsM then pcall(function() InteriorsM.enter_smooth("housing","MainDoor",{house_owner=LocalPlayer}) end) end
        return
    end

    local housingUser = t:match("^[Tt]eleport/[Hh]ousing/(.+)$")
    if housingUser and housingUser:lower() ~= "me" then
        local p = game:GetService("Players"):FindFirstChild(housingUser)
        if p and InteriorsM then pcall(function() InteriorsM.enter_smooth("housing","MainDoor",{house_owner=p}) end) end
        return
    end

    local tpUser = t:match("^[Tt]eleport/[Tt][Pp]/(.+)$")
    if tpUser then
        task.spawn(function()
            local target = game:GetService("Players"):FindFirstChild(tpUser)
            if not target then return end
            local loc
            local ClientData2
            pcall(function() ClientData2 = Fsys("ClientData") end)
            if ClientData2 then
                pcall(function()
                    local raw = ClientData2.get_server(target,"char_wrapper_raw")
                    if raw and raw.location then loc = raw.location end
                end)
            end
            if loc and loc.full_destination_id and InteriorsM then
                local dest = loc.full_destination_id
                local owner = loc.house_owner
                pcall(function()
                    if dest:lower():sub(1,7) == "housing" and owner then
                        InteriorsM.enter_smooth("housing","MainDoor",{house_owner=owner})
                    else
                        InteriorsM.enter_smooth(dest,"MainDoor",{})
                    end
                end)
                task.wait(1.5)
                local myChar = LocalPlayer.Character
                local targetChar = target.Character
                if myChar and targetChar then
                    local hrp = targetChar:FindFirstChild("HumanoidRootPart")
                    local myHrp = myChar:FindFirstChild("HumanoidRootPart")
                    if hrp and myHrp then myHrp.CFrame = hrp.CFrame * CFrame.new(2,0,0) end
                end
            end
        end)
        return
    end

    local dest, user = t:match("^[Tt]eleport/([^/]+)/(.+)$")
    if dest and user then
        task.spawn(function()
            if InteriorsM then
                local owner = nil
                if user:lower() ~= "me" then
                    local p = game:GetService("Players"):FindFirstChild(user)
                    if p then owner = p end
                end
                pcall(function() InteriorsM.enter_smooth(dest,"MainDoor", owner and {house_owner=owner} or {}) end)
            end
        end)
        return
    end
end

-- Hook chat
pcall(function() LocalPlayer.Chatted:Connect(handleCmd) end)
task.spawn(function()
    local TCS = game:GetService("TextChatService")
    local channels
    for i=1,100 do
        channels = TCS:FindFirstChild("TextChannels")
        if channels then break end
        task.wait(0.1)
    end
    if not channels then return end
    local function hookCh(ch)
        if not ch:IsA("TextChannel") then return end
        ch.MessageReceived:Connect(function(msg)
            if not msg then return end
            local src = msg.TextSource
            if src and src.UserId == LocalPlayer.UserId then handleCmd(msg.Text) end
        end)
    end
    for _,ch in ipairs(channels:GetChildren()) do hookCh(ch) end
    channels.ChildAdded:Connect(hookCh)
end)

