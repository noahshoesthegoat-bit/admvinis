-- Safe thread identity
local function getIdentity()
    if type(get_thread_identity) == "function" then return get_thread_identity() end
    if type(getthreadidentity) == "function" then return getthreadidentity() end
    return 2
end
local function setIdentity(n)
    if type(set_thread_identity) == "function" then pcall(set_thread_identity, n) return end
    if type(setthreadidentity) == "function" then pcall(setthreadidentity, n) return end
end

