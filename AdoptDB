if RouterClient then
    local orig = RouterClient.get
    RouterClient.get = function(ep)
        if ep == "ToolAPI/Equip" then
            return {InvokeServer=function(_,uid,opts)
                local pet = SpawnedPets[uid]
                if not pet then return orig("ToolAPI/Equip"):InvokeServer(uid,opts) end
                EquipPet(pet.data, opts)
                return true, {action="equip", is_server=true}
            end}
        elseif ep == "ToolAPI/Unequip" then
            return {InvokeServer=function(_,uid)
                local pet = SpawnedPets[uid]
                if not pet then return orig("ToolAPI/Unequip"):InvokeServer(uid) end
                UnequipPet(pet.data)
                return true, {action="unequip", is_server=true}
            end}
        elseif ep == "AdoptAPI/RidePet" then
            return {InvokeServer=function(_,pd)
                local pet = SpawnedPets[pd.pet_unique]
                if not pet then return orig("AdoptAPI/RidePet"):InvokeServer(pd) end
                Mount(pd.pet_unique, "PlayerRidingPet", "PetBeingRidden")
                return true
            end}
        elseif ep == "AdoptAPI/FlyPet" then
            return {InvokeServer=function(_,pd)
                local pet = SpawnedPets[pd.pet_unique]
                if not pet then return orig("AdoptAPI/FlyPet"):InvokeServer(pd) end
                Mount(pd.pet_unique, "PlayerFlyingPet", "PetBeingFlown")
                return true
            end}
        elseif ep == "AdoptAPI/ExitSeatStates" then
            return {FireServer=function()
                if CurrentRideId then Dismount() return true end
                return orig("AdoptAPI/ExitSeatStates"):FireServer()
            end}
        elseif ep == "SettingsAPI/SetPetRoleplayName" then
            return {InvokeServer=function(_,uid,name)
                local pet = SpawnedPets[uid]
                if not pet then return orig("SettingsAPI/SetPetRoleplayName"):InvokeServer(uid,name) end
                local id2 = getIdentity() setIdentity(2)
                local inv = ClientData.get("inventory")
                if inv and inv.pets and inv.pets[uid] then inv.pets[uid].properties.rp_name = name end
                if pet.data then pet.data.properties.rp_name = name end
                setIdentity(id2)
                pcall(function()
                    UpdateClientData("pet_char_wrappers", function(w)
                        for _,v in pairs(w) do if v.pet_unique == uid then v.rp_name = name end end
                        return w
                    end)
                end)
                return true
            end}
        else
            return orig(ep)
        end
    end
end

local function CreateItem(itemId, category, properties)
    local uid = GenUID()
    local kd = KindDB and KindDB[itemId]
    properties = properties or {}
    local nv = NextToyOrder
    if category == "pets" then
        local gk = GetPropertyGroup(properties)
        NewnessGroups[gk] = NewnessGroups[gk] - 1
        nv = NewnessGroups[gk]
        properties.ailments_completed = properties.ailments_completed or 0
        if properties.rp_name == nil then properties.rp_name = "" end
        properties.xp = properties.xp or 0
        properties.friendship_level = properties.friendship_level or 1
        properties.friendship_xp = properties.friendship_xp or 0
    else
        NextToyOrder = NextToyOrder - 1
        nv = NextToyOrder
    end
    local item = {unique=uid, category=category, id=itemId, kind=kd.kind, newness_order=nv, properties=properties, _source="AAPanel"}
    local id2 = getIdentity() setIdentity(2)
    local inv = ClientData.get("inventory")
    if inv and inv[category] then inv[category][uid] = item end
    setIdentity(id2)
    if category == "pets" then SpawnedPets[uid] = {data=item, model=nil} end
    SpawnedItems[uid] = true
    task.defer(function()
        local UIManager
        pcall(function() UIManager = Fsys("UIManager") end)
        if UIManager and UIManager.apps and UIManager.apps.BackpackApp then
            UIManager.apps.BackpackApp:refresh_rendered_items()
        end
    end)
    return item
end

local function findItem(name)
    if not InventoryDB then return nil,nil,nil end
    local nameLower = name:lower()
    for _,cat in ipairs({"pets","toys","food","vehicles","strollers","gifts"}) do
        local tbl = InventoryDB[cat]
        if type(tbl) == "table" then
            for id,v in pairs(tbl) do
                if type(v) == "table" then
                    -- Match by display name OR by kind/id key
                    if (v.name and v.name:lower() == nameLower) or id:lower() == nameLower then
                        return id, cat, v
                    end
                end
            end
        end
    end
    return nil,nil,nil
end

